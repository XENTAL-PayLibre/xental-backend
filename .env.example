# Xental API — environment configuration template.
# Copy to `.env` and adjust per environment. `.env` is git-ignored.
# Double underscore (__) maps to nested config keys in .NET (e.g. ConnectionStrings:Default).

# ---- ASP.NET Core runtime ----
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_HTTP_PORTS=8080

# ---- Docker host port mapping ----
# Host port the API is published on (container always listens on 8080).
API_PORT=8080

# ---- Database (PostgreSQL) ----
ConnectionStrings__Default=Host=postgres;Port=5432;Database=xental;Username=xental_app;Password=changeme

# ---- JWT (northbound API auth) ----
# SigningKey MUST be at least 32 bytes and is a SECRET — override per environment.
Jwt__SigningKey=change-me-to-a-long-random-secret-at-least-32-bytes
Jwt__Issuer=xental
Jwt__Audience=xental-api
# Lifetime of an API (client-credentials) token, seconds.
Jwt__AccessTokenLifetimeSeconds=3600
# Lifetime of a dashboard access token (short; paired with a refresh token), seconds.
Jwt__DashboardTokenLifetimeSeconds=900

# ---- Nomba (southbound integration) ----
# The operator holds ONE Nomba account (set up once in the dashboard). Users never
# touch Nomba. Staging should use SANDBOX credentials; production uses LIVE ones.
Nomba__BaseUrl=https://api.nomba.com/v1/
# Parent account id — sent as the `accountId` header on every call.
Nomba__AccountId=
# Platform sub-account id — virtual accounts (NUBANs) are created under this (Phase 2).
Nomba__SubAccountId=
Nomba__ClientId=
Nomba__ClientSecret=
# Serve a cached Nomba token for this long before refreshing (Nomba tokens expire
# in 30 min; refresh ~5 min early = 25 min).
Nomba__TokenRefreshSeconds=1500
# Webhook signing key (from Nomba) used to verify the `nomba-signature` header.
Nomba__WebhookSecret=
Nomba__WebhookSignatureHeader=nomba-signature

# ---- App ----
# FRONTEND URL (user-facing pages: email-verified, reset-password, OAuth callback).
App__BaseUrl=http://localhost:3000
# This API's public URL (target of the email-verification magic link). Falls back to
# App__BaseUrl if empty. In prod: https://api.xental.online
App__ApiBaseUrl=http://localhost:8080

# ---- Auth (developer accounts) ----
# Bcrypt work factor for password hashing (>=12 recommended).
Auth__BcryptWorkFactor=12
# Minutes a magic-link email-verification token stays valid.
Auth__EmailVerificationTtlMinutes=30
# Minutes a password-reset link stays valid.
Auth__PasswordResetTtlMinutes=30
# Days a dashboard refresh token stays valid.
Auth__RefreshTokenDays=14
# Session cookies require HTTPS (Secure flag). Keep true everywhere except plain-HTTP local dev.
Auth__CookieSecure=true
# Cookie domain for session cookies. Empty = host-only (recommended). Set e.g. ".xental.online"
# only if you need the cookie shared across sibling subdomains.
Auth__CookieDomain=

# ---- CORS ----
# Comma-separated frontend origins allowed to call the API with credentials (cookies).
# Empty = same-origin only. e.g. https://app.xental.online
Cors__AllowedOrigins=
# Google OAuth (Google Cloud Console -> APIs & Services -> Credentials -> OAuth client).
# Authorized redirect URI to register: {App__BaseUrl}/api/v1/auth/oauth/google/callback
Auth__Google__ClientId=
Auth__Google__ClientSecret=
# GitHub OAuth (GitHub -> Settings -> Developer settings -> OAuth Apps).
# Authorization callback URL to register: {App__BaseUrl}/api/v1/auth/oauth/github/callback
Auth__GitHub__ClientId=
Auth__GitHub__ClientSecret=

# ---- Resend (transactional email for magic-link verification) ----
# API key from resend.com; FromEmail must be on a verified sender domain.
Resend__ApiKey=
Resend__FromEmail=no-reply@yourdomain.com
