# Xental API — environment configuration template.
# Copy to `.env` and adjust per environment. `.env` is git-ignored.

# ---- ASP.NET Core runtime ----
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_HTTP_PORTS=8080

# ---- Docker host port mapping ----
# Host port the API is published on (container always listens on 8080).
API_PORT=8080

# ---- Application settings (placeholders for upcoming modules) ----
# Double underscore maps to nested config keys in .NET (e.g. ConnectionStrings:Default).
# ConnectionStrings__Default=Host=db;Port=5432;Database=xental;Username=xental;Password=changeme
