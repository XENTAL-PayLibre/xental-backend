{
  "name": "xental-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for Xental — lets any MCP-capable agent operate a Xental account (virtual accounts, transactions, transfers, sandbox).",
  "type": "module",
  "bin": {
    "xental-mcp": "build/index.js"
  },
  "files": ["build"],
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "tsc && node build/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0"
  }
}
